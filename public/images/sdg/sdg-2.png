    <!-- Steam lines -->
    <path d="M40 25 Q45 10 40 0" fill="none" stroke="white" stroke-width="4" stroke-linecap="round"/>
    <path d="M65 25 Q70 10 65 0" fill="none" stroke="white" stroke-width="4" stroke-linecap="round"/>
    <path d="M90 25 Q95 10 90 0" fill="none" stroke="white" stroke-width="4" stroke-linecap="round"/>
  </g>
</svg>
