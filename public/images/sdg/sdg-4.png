<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200">
  <rect width="200" height="200" fill="#C5192D"/>
  <text x="15" y="35" font-family="Arial, sans-serif" font-size="18" font-weight="bold" fill="white">4</text>
  <text x="15" y="55" font-family="Arial, sans-serif" font-size="11" font-weight="bold" fill="white">QUALITY</text>
  <text x="15" y="68" font-family="Arial, sans-serif" font-size="11" font-weight="bold" fill="white">EDUCATION</text>
  <!-- Book icon -->
  <g transform="translate(55, 80)">
    <path d="M45 0 L45 70 L0 55 L0 0 Z" fill="none" stroke="white" stroke-width="4"/>
    <path d="M45 0 L45 70 L90 55 L90 0 Z" fill="none" stroke="white" stroke-width="4"/>
    <line x1="45" y1="0" x2="45" y2="70" stroke="white" stroke-width="4"/>
    <!-- Pencil -->
    <rect x="60" y="-15" width="6" height="50" fill="white" transform="rotate(15, 63, 10)"/>
    <polygon points="60,-15 63,-25 66,-15" fill="white" transform="rotate(15, 63, 10)"/>
  </g>
</svg>
