<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200">
  <rect width="200" height="200" fill="#FF3A21"/>
  <text x="15" y="35" font-family="Arial, sans-serif" font-size="18" font-weight="bold" fill="white">5</text>
  <text x="15" y="55" font-family="Arial, sans-serif" font-size="11" font-weight="bold" fill="white">GENDER</text>
  <text x="15" y="68" font-family="Arial, sans-serif" font-size="11" font-weight="bold" fill="white">EQUALITY</text>
  <!-- Gender equality symbol -->
  <g transform="translate(60, 85)">
    <circle cx="40" cy="25" r="22" fill="none" stroke="white" stroke-width="5"/>
    <line x1="40" y1="47" x2="40" y2="85" stroke="white" stroke-width="5"/>
    <line x1="25" y1="65" x2="55" y2="65" stroke="white" stroke-width="5"/>
    <line x1="56" y1="9" x2="75" y2="-10" stroke="white" stroke-width="5"/>
    <line x1="62" y1="-10" x2="75" y2="-10" stroke="white" stroke-width="5"/>
    <line x1="75" y1="-10" x2="75" y2="3" stroke="white" stroke-width="5"/>
    <line x1="40" y1="85" x2="30" y2="95" stroke="white" stroke-width="5"/>
    <line x1="40" y1="85" x2="50" y2="95" stroke="white" stroke-width="5"/>
  </g>
</svg>
